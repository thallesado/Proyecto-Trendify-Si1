# Variables de entorno para produccion (Cloud Run).
# NO COMMITEAR el .env real con estos valores - guardarlos en Secret Manager.

# Generar uno con: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=cambiar-por-uno-real-de-50-caracteres

DEBUG=False

# Hostname publico de Cloud Run + custom domain si tienes
ALLOWED_HOSTS=trendify-backend-xxxx.run.app,*.run.app

# Postgres en Cloud SQL (formato Unix socket cuando se usa --add-cloudsql-instances)
DATABASE_URL=postgres://trendify:<password>@/cosmetica_sistema?host=/cloudsql/PROJECT_ID:southamerica-east1:trendify-db

# Origen del frontend Firebase Hosting (separar con coma sin espacios)
CORS_ALLOWED_ORIGINS=https://FIREBASE_PROJECT_ID.web.app,https://FIREBASE_PROJECT_ID.firebaseapp.com

# CSRF: mismos hosts que CORS_ALLOWED_ORIGINS
CSRF_TRUSTED_ORIGINS=https://FIREBASE_PROJECT_ID.web.app,https://FIREBASE_PROJECT_ID.firebaseapp.com
